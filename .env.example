# Скопируйте в .env и заполните.

# Токен Telegram-бота (обязателен для bot.py) — из @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# UZUM_API_TOKEN больше не нужен глобально — токен Uzum каждый юзер присылает боту.
# UZUM_API_TOKEN=ваш_токен_без_префикса_Bearer  # нужен только для старого однопользовательского режима

# Ключ шифрования токенов (Fernet). Если пуст — сгенерируется автоматически в .env.
ENCRYPTION_KEY=

# Telegram-id админов через запятую (доступ к /stats). Пример: ADMIN_IDS=12345,67890
ADMIN_IDS=

# UZUM_DB_URL=sqlite:///data/uzum.db
# UZUM_LOG_LEVEL=INFO
# UZUM_DB_ECHO=0

# Окружение: проект ориентирован строго на Python 3.12, единый .venv (см. setup_bot.sh).
